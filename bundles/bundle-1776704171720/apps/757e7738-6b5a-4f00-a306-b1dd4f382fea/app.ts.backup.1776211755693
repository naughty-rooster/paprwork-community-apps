import type { Task, CalendarItem, Project, MessageCandidate } from './types.ts';
import { dbQuery, dbWrite, triggerJob } from './utils/helpers.ts';
import { renderToday, renderAll } from './components/renderTasks.ts';
import { renderProjects } from './components/renderProjects.ts';
import { renderCalendar, renderHow, renderModal } from './components/renderShared.ts';
import { renderMessages } from './components/renderMessages.ts';
let tasks:Task[]=[], items:CalendarItem[]=[], projects:Project[]=[], candidates:MessageCandidate[]=[];
let currentTab='today', filterStatus='active', searchQuery='', showAddModal=false, selectedTask:Task|null=null, modalMode='task';
const app=()=>document.getElementById('app')!;
function body(){ return currentTab==='today'?renderToday(tasks)+renderCalendar(items):currentTab==='all'?renderAll(tasks,filterStatus,searchQuery):currentTab==='projects'?renderProjects(projects,tasks):renderHow()+renderMessages(candidates); }
function main(){ app().innerHTML=`<div class="header"><div class="header-left"><div class="app-icon">📋</div><div><div class="app-title">Personal Admin Assistant</div><div class="app-subtitle">${new Date().toLocaleDateString('en',{weekday:'long',month:'long',day:'numeric'})}</div></div></div><div class="header-actions"><button class="btn-secondary" onclick="loadData()">↻</button><button class="btn-secondary" onclick="openRecurring()">↺ Recurring</button><button class="btn-primary" onclick="openAdd()">+ Add Task</button></div></div><div class="tabs"><div class="tab ${currentTab==='today'?'active':''}" onclick="switchTab('today')">📌 Focus</div><div class="tab ${currentTab==='all'?'active':''}" onclick="switchTab('all')">📋 Tasks</div><div class="tab ${currentTab==='projects'?'active':''}" onclick="switchTab('projects')">📁 Projects</div><div class="tab ${currentTab==='how'?'active':''}" onclick="switchTab('how')">💡 Add</div></div><div class="main">${body()}</div>${showAddModal?renderModal(selectedTask,modalMode):''}<div class="toast" id="toast"></div>`;
  document.getElementById('modal-overlay')?.addEventListener('click',e=>{ if((e.target as HTMLElement).id==='modal-overlay') closeModal(); }); }
async function loadData(){ app().innerHTML='<div class="loading"><div class="spinner"></div> Loading…</div>';
  [tasks,items,projects,candidates]=await Promise.all([dbQuery('SELECT * FROM tasks ORDER BY priority ASC, due_date ASC NULLS LAST, created_at DESC'),dbQuery('SELECT * FROM calendar_items ORDER BY event_date ASC, starts_at ASC'),dbQuery('SELECT * FROM projects ORDER BY name ASC'),dbQuery("SELECT * FROM message_candidates WHERE status='new' AND datetime(message_date) >= datetime('now','-21 days') AND COALESCE(json_extract(source_details,'$.category'),'') != 'family-logistics' ORDER BY datetime(message_date) DESC, score DESC LIMIT 12")]); main(); }
const toast=(m:string)=>{ const el=document.getElementById('toast'); if(!el) return; el.textContent=m; el.classList.add('show'); setTimeout(()=>el.classList.remove('show'),2500); };
const closeModal=()=>{ showAddModal=false; selectedTask=null; modalMode='task'; main(); }, openAdd=()=>{ selectedTask=null; modalMode='task'; showAddModal=true; main(); }, openRecurring=()=>{ selectedTask=null; modalMode='recurring'; showAddModal=true; main(); };
const run=async(jobId:string,msg:string)=>{ toast(msg); await triggerJob(jobId); setTimeout(loadData,3000); };
(window as any).loadData=loadData; (window as any).switchTab=(t:string)=>{ currentTab=t; main(); }; (window as any).openAdd=openAdd; (window as any).openRecurring=openRecurring; (window as any).closeModal=closeModal;
(window as any).setFilter=(f:string)=>{ filterStatus=f; main(); }; (window as any).onSearch=(v:string)=>{ searchQuery=v; main(); }; (window as any).editTask=(id:number)=>{ selectedTask=tasks.find(t=>t.id===id)||null; modalMode='task'; showAddModal=true; main(); };
(window as any).toggleDone=async(id:number)=>{ const t=tasks.find(x=>x.id===id); if(!t) return; const s=t.status==='done'?'open':'done'; await dbWrite("UPDATE tasks SET status=?,updated_at=datetime('now') WHERE id=?",[s,id]); t.status=s; main(); toast(s==='done'?'✅ Completed':'↩️ Reopened'); };
(window as any).deleteTask=async(id:number)=>{ if(!confirm('Delete this task?')) return; await dbWrite('DELETE FROM tasks WHERE id=?',[id]); tasks=tasks.filter(t=>t.id!==id); main(); toast('🗑️ Deleted'); };
(window as any).saveTask=async()=>{ const title=((document.getElementById('inp-title') as HTMLInputElement)?.value||'').trim(); if(!title) return; const desc=((document.getElementById('inp-desc') as HTMLTextAreaElement)?.value||'').trim(), due=(document.getElementById('inp-due') as HTMLInputElement)?.value||null, priority=parseInt((document.getElementById('inp-priority') as HTMLSelectElement)?.value||'2');
  if(selectedTask) await dbWrite("UPDATE tasks SET title=?,description=?,due_date=?,priority=?,updated_at=datetime('now') WHERE id=?",[title,desc,due,priority,selectedTask.id]); else await dbWrite('INSERT INTO tasks (title,description,due_date,priority,status,source) VALUES (?,?,?,?\,'open','manual')',[title,desc,due,priority]); closeModal(); await loadData(); toast('✅ Saved'); };
(window as any).saveRecurring=async()=>{ const title=((document.getElementById('inp-title') as HTMLInputElement)?.value||'').trim(); const due=(document.getElementById('inp-due') as HTMLInputElement)?.value||''; if(!title||!due) return; const desc=((document.getElementById('inp-desc') as HTMLTextAreaElement)?.value||'').trim(), priority=parseInt((document.getElementById('inp-priority') as HTMLSelectElement)?.value||'2'), frequency=(document.getElementById('inp-frequency') as HTMLSelectElement)?.value||'weekly', intervalN=parseInt((document.getElementById('inp-interval') as HTMLInputElement)?.value||'1'), dt=new Date(due+'T00:00:00'), weekday=(dt.getDay()+6)%7, day=dt.getDate();
  await dbWrite('INSERT INTO recurring_templates (title,description,priority,frequency,interval_n,start_date,next_due_date,weekday,day_of_month,status) VALUES (?,?,?,?,?,?,?,?,?,'active')',[title,desc,priority,frequency,intervalN,due,due,weekday,day]); const row=await dbQuery('SELECT id FROM recurring_templates ORDER BY id DESC LIMIT 1'); const details=JSON.stringify({recurring_template_id:row[0]?.id,frequency,interval_n:intervalN}); await dbWrite('INSERT INTO tasks (title,description,due_date,priority,status,source,source_details) VALUES (?,?,?,?\,'open','recurring',?)',[title,desc,due,priority,details]); await triggerJob('4ef2431d-2fb3-4d93-9456-374eaceffbee'); closeModal(); await loadData(); toast('↺ Recurring task saved'); };
(window as any).promoteCandidate=async(id:number)=>{ const c=candidates.find(x=>x.id===id); if(!c) return; await dbWrite('INSERT INTO tasks (title,description,priority,status,source,source_details) VALUES (?,?,?,?,?,?)',[c.message_text.slice(0,120),c.message_text,2,'open','messages',c.source_details]); await dbWrite("UPDATE message_candidates SET status='promoted',updated_at=datetime('now') WHERE id=?",[id]); candidates=candidates.filter(x=>x.id!==id); await loadData(); toast('✅ Promoted to task'); };
(window as any).ignoreCandidate=async(id:number)=>{ await dbWrite("UPDATE message_candidates SET status='ignored',updated_at=datetime('now') WHERE id=?",[id]); candidates=candidates.filter(x=>x.id!==id); main(); toast('🙈 Ignored'); };
(window as any).triggerGmailScan=()=>run('8bbffe39-dc3b-4b73-aec6-2bfc3356dd82','🔍 Scanning Gmail...'); (window as any).triggerEmailIngest=()=>run('737c7fef-1c21-4522-85f1-9d4388a080f2','📧 Checking emailed tasks...');
(window as any).triggerCalendarSync=()=>run('bb9064f6-b300-4866-b3c7-a9b47dcbdf4c','🗓 Syncing calendar...'); (window as any).triggerMessagesScan=()=>run('1833eaea-ea37-427d-bf45-b02c063f00cd','💬 Scanning Messages...');
(window as any).triggerCalendarWriter=()=>run('9119a317-00c7-499a-8d94-f16c67327d66','🗓 Adding appointment texts to Google Calendar...'); loadData();
