import type { Project, Task } from '../types.ts';
import { esc, parsePlan } from '../utils/helpers.ts';
const tone=(p:Project)=>p.planning_status==='queued'?'⏳ Pen is drafting next steps…':p.planning_status==='done'&&p.planning_summary?`✨ ${esc(p.planning_summary)}`:p.planning_status==='error'&&p.planning_summary?`⚠️ ${esc(p.planning_summary)}`:'Paste context, click ✨ Research, then stage the best steps.';
export function renderProjects(projects:Project[],tasks:Task[]){ const weekEnd=new Date(); weekEnd.setDate(weekEnd.getDate()+7); const cards=projects.map(p=>{ const linked=tasks.filter(t=>(t.tags||'').includes(`project:${p.name}`)&&t.status==='open'), dueSoon=linked.filter(t=>t.due_date&&new Date(`${t.due_date}T12:00:00`)<=weekEnd), auto=linked.filter(t=>String(t.source_details||'').includes('project_link_reason')), plan=parsePlan(p.plan_json), notes=p.notes?`<div class="mini-task" style="margin-top:8px">${esc(p.notes.slice(0,160))}</div>`:'', status=`<div class="mini-task" style="margin-top:8px">${tone(p)}</div>`; return `<div class="project-card"><div class="project-head"><div onclick="openProject(${p.id})" style="cursor:pointer"><div class="project-title">${esc(p.name)}</div><div class="project-objective">${esc(p.objective||'')}</div></div><div class="section-count">${linked.length} open</div></div><div class="task-meta" style="margin:8px 0 10px"><span class="task-date">🗓 ${dueSoon.length} due soon</span>${auto.length?`<span class="task-date">🔗 ${auto.length} auto-linked</span>`:''}</div><ul class="project-plan">${plan.map(x=>`<li>${esc(x)}</li>`).join('')||'<li>No plan yet.</li>'}</ul>${status}${notes}<div class="project-linked"><div class="mini-label">Current linked tasks</div>${linked.length?linked.slice(0,4).map(t=>`<div class="mini-task">• ${esc(t.title)}</div>`).join(''):'<div class="mini-task">No linked tasks yet.</div>'}</div><div class="modal-actions" style="margin-top:12px"><button class="btn-secondary" onclick="openProject(${p.id})">Review / stage</button><button class="btn-secondary" onclick="openProject(${p.id});setTimeout(()=>queueProjectPlan(),60)">✨ Research</button></div></div>`; }).join(''); return `<div class="section"><div class="section-header"><div class="section-title">📁 Ongoing Projects</div><button class="btn-secondary" onclick="openProject()">+ Project</button></div>${cards||'<div class="empty-state"><div class="empty-icon">📁</div><div class="empty-title">No projects yet</div><div class="empty-sub">Create a project, add context, then let Pen draft next steps you can stage into tasks.</div></div>'}</div>`; }
