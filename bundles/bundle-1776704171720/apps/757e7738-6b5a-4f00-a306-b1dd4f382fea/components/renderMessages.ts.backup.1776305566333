import type { MessageCandidate } from '../types.ts';
import { esc } from '../utils/helpers.ts';
const when=(d:string|null)=>d?new Date(d.replace(' ','T')).toLocaleDateString('en',{month:'short',day:'numeric'})+' · '+new Date(d.replace(' ','T')).toLocaleTimeString('en',{hour:'numeric',minute:'2-digit'}):'';
const meta=(m:MessageCandidate)=>{ try{ return JSON.parse(m.source_details||'{}'); }catch{return {};} };
const label=(m:MessageCandidate)=>({admin:'💼 Admin',medical:'🩺 Medical',scheduling:'📅 Scheduling','reply-needed':'↩️ Reply',logistics:'📝 Logistics','family-logistics':'🏠 Family'}[(meta(m).reason||'')]||({ 'medical-admin':'🩺 Medical','personal-admin':'💼 Admin'}[(meta(m).category||'')]||'💬 Candidate'));
const row=(m:MessageCandidate)=>{ const d=meta(m), hint=d.category==='medical-admin'?'Medical / billing':d.category==='personal-admin'?'Personal admin':'Review'; return `<div class="task-card"><div class="task-content"><div class="task-title">${esc(m.contact||'Unknown contact')}</div><div class="task-description">${esc(m.message_text.slice(0,180))}</div><div class="task-meta"><span class="task-badge badge-email">${label(m)}</span><span class="task-date">${when(m.message_date)}</span><span class="task-date">${esc(hint)}</span></div></div><div class="task-actions"><button class="icon-btn" onclick="promoteCandidate(${m.id})">➕</button><button class="icon-btn" onclick="ignoreCandidate(${m.id})">✕</button></div></div>`; };
export function renderMessages(items:MessageCandidate[]){
  return `<div class="section"><div class="section-header"><div class="section-title">💬 Text candidates<span class="section-count">${items.length}</span></div></div>${items.length?`<div class="task-list">${items.map(row).join('')}</div>`:'<div class="empty-state"><div class="empty-icon">💬</div><div class="empty-title">No text candidates yet</div></div>'}</div>`;
}
