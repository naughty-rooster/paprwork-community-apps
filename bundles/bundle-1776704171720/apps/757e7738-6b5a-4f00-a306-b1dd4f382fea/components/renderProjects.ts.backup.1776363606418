  const weekly=`<div class="section"><div class="section-header"><div class="section-title">📝 Weekly project brief</div></div><div class="review-grid">${brief('Meetings this week',meetingProjects,'No project-linked meetings scheduled this week.','📅',x=>`${x.meetings.length} event${x.meetings.length===1?'':'s'} · ${x.meetings[0]?.title||'Upcoming event'}`)}${brief('Waiting on communication',waiting,'No projects currently look blocked on replies or review emails.','✉️',x=>smartTaskTitle(x.comms[0]))}${brief('Needs a next action',needsNext,'Every active project already has a next action.','✅',x=>x.p.objective||'Add a next step so the project keeps moving')}</div></div>`;
  const cards=rows.map(({p,linked,due,auto,plan,comms,upcoming})=>{ const notes=p.notes?`<div class="mini-task" style="margin-top:8px">${esc(p.notes.slice(0,160))}</div>`:'',status=`<div class="mini-task" style="margin-top:8px">${tone(p)}</div>`,signal=comms[0]?`<div class="mini-task" style="margin-top:8px"><strong>Latest signal:</strong> ${esc(smartTaskTitle(comms[0]))}</div>`:upcoming[0]?`<div class="mini-task" style="margin-top:8px"><strong>Upcoming:</strong> ${esc(upcoming[0].title)} · ${esc(formatDue(upcoming[0].event_date||'').text||upcoming[0].event_date||'')}</div>`:linked[0]?`<div class="mini-task" style="margin-top:8px"><strong>Next task:</strong> ${esc(smartTaskTitle(linked[0]))}</div>`:''; return `<div class="project-card"><div class="project-head"><div onclick="openProject(${p.id})" style="cursor:pointer"><div class="project-title">${esc(p.name)}</div><div class="project-objective">${esc(p.objective||'')}</div></div><div class="section-count">${linked.length} open</div></div><div class="task-meta" style="margin:8px 0 10px"><span class="task-date">🗓 ${due.length} due this week</span>${upcoming.length?`<span class="task-date">📅 ${upcoming.length} upcoming events</span>`:''}${comms.length?`<span class="task-date">✉️ ${comms.length} related emails/messages</span>`:''}${auto.length?`<span class="task-date">🔗 ${auto.length} auto-linked</span>`:''}${p.status!=='active'?`<span class="task-date">${esc(p.status)}</span>`:''}</div><ul class="project-plan">${plan.map(x=>`<li>${esc(x)}</li>`).join('')||'<li>No plan yet.</li>'}</ul>${status}${signal}${notes}<div class="project-linked"><div class="mini-label">Current linked tasks</div>${linked.length?linked.slice(0,4).map(t=>`<div class="mini-task">• ${esc(smartTaskTitle(t))}</div>`).join(''):'<div class="mini-task">No linked tasks yet.</div>'}</div><div class="modal-actions" style="margin-top:12px"><button class="btn-secondary" onclick="openProject(${p.id})">Review / stage</button><button class="btn-secondary" onclick="openProject(${p.id});setTimeout(()=>queueProjectPlan(),60)">✨ Research</button></div></div>`; }).join('');
  return `${weekly}${review}<div class="section"><div class="section-header"><div class="section-title">📁 Ongoing Projects</div><button class="btn-secondary" onclick="openProject()">+ Project</button></div>${cards||'<div class="empty-state"><div class="empty-icon">📁</div><div class="empty-title">No projects yet</div><div class="empty-sub">Create a project, add context, then let Pen draft next steps you can stage into tasks.</div></div>'}</div>`;
}
