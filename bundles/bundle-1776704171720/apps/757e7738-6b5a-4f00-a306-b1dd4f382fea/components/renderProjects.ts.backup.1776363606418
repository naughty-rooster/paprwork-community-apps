import type { Project, Task, CalendarItem } from '../types.ts';
import { esc, formatDue, parseJson, parsePlan, smartTaskTitle, weekBounds } from '../utils/helpers.ts';
const day=(s='')=>s?new Date(`${s}T12:00:00`):null,age=(s='')=>s?Math.floor((Date.now()-new Date(s).getTime())/86400000):999;
const tone=(p:Project)=>p.planning_status==='queued'?'⏳ Pen is drafting next steps…':p.planning_status==='done'&&p.planning_summary?`✨ ${esc(p.planning_summary)}`:p.planning_status==='error'&&p.planning_summary?`⚠️ ${esc(p.planning_summary)}`:'Paste context, click ✨ Research, then stage the best steps.';
const proj=(t:Task)=>((t.tags||'').match(/(?:^|,)project:([^,]+)/)?.[1]||'').trim();
const itemProj=(i:CalendarItem)=>parseJson(i.source_details).project||'';
export function renderProjects(projects:Project[],tasks:Task[],items:CalendarItem[]){
  const {start,end}=weekBounds(),today=new Date(new Date().toDateString()),soon=new Date(today); soon.setDate(today.getDate()+14); soon.setHours(23,59,59,999);
  const rows=projects.map(p=>{ const linked=tasks.filter(t=>proj(t)===p.name&&t.status==='open'), allLinked=tasks.filter(t=>proj(t)===p.name), comms=allLinked.filter(t=>['gmail','email_in','messages','text_in','sms','sms_in'].includes(t.source)).sort((a,b)=>(b.created_at||'').localeCompare(a.created_at||'')), ev=items.filter(i=>itemProj(i)===p.name).sort((a,b)=>`${a.event_date||''} ${a.starts_at||''}`.localeCompare(`${b.event_date||''} ${b.starts_at||''}`)), due=linked.filter(t=>{const d=day(t.due_date||''); return !!d&&d<=end;}), overdue=linked.filter(t=>{const d=day(t.due_date||''); return !!d&&d<today;}), auto=linked.filter(t=>String(t.source_details||'').includes('project_link_reason')), meetings=ev.filter(i=>{const d=day(i.event_date||''); return !!d&&d>=today&&d<=end;}), upcoming=ev.filter(i=>{const d=day(i.event_date||''); return !!d&&d>=today&&d<=soon;}), plan=parsePlan(p.plan_json), touched=Math.min(age((p as any).updated_at||''),age(p.planning_requested_at||'')), needsNext=p.status==='active'&&!linked.length, stalled=p.status==='active'&&linked.length>0&&!due.length&&touched>10; return {p,linked,allLinked,comms,ev,due,overdue,auto,meetings,upcoming,plan,needsNext,stalled}; });
  const active=rows.filter(x=>x.p.status==='active'), needsNext=active.filter(x=>x.needsNext), dueWeek=active.filter(x=>x.due.length), stalled=active.filter(x=>x.stalled), meetingProjects=active.filter(x=>x.meetings.length), waiting=active.filter(x=>x.comms.some(t=>/reply|respond|confirm|review|decision|approve/i.test(`${t.title} ${t.description||''}`)));
  const stats=`<div class="stats-row"><div class="stat-card"><div class="stat-num">${active.length}</div><div class="stat-label">Active</div></div><div class="stat-card"><div class="stat-num" style="color:var(--high)">${dueWeek.length}</div><div class="stat-label">Due this week</div></div><div class="stat-card"><div class="stat-num" style="color:var(--medium)">${needsNext.length}</div><div class="stat-label">Needs next step</div></div><div class="stat-card"><div class="stat-num" style="color:var(--low)">${stalled.length}</div><div class="stat-label">Stalled</div></div></div>`;
  const reviewList=(title:string,set:typeof rows,hint:string,icon:string)=>`<div class="review-card"><div class="section-header"><div class="section-title">${icon} ${title}<span class="section-count">${set.length}</span></div></div>${set.length?`<div class="review-list">${set.slice(0,5).map(({p,linked,due,overdue,plan})=>`<button class="review-row" onclick="openProject(${p.id})"><div><div class="review-row-title">${esc(p.name)}</div><div class="review-row-sub">${overdue.length?`${overdue.length} overdue · `:''}${due.length?`${due.length} due this week`:linked.length?`${linked.length} open tasks`:'No open tasks'}${!plan.length?' · No drafted plan':''}</div></div><span class="task-date">${due[0]?.due_date?formatDue(due[0].due_date).text:''}</span></button>`).join('')}</div>`:`<div class="instr-desc">${hint}</div>`}</div>`;
