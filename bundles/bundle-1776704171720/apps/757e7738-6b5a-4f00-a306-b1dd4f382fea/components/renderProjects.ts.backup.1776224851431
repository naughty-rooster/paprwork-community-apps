import type { Project, Task } from '../types.ts';
import { esc, parsePlan } from '../utils/helpers.ts';
export function renderProjects(projects:Project[],tasks:Task[]){
  const cards=projects.map(p=>{ const linked=tasks.filter(t=>(t.tags||'').includes(`project:${p.name}`)&&t.status==='open'), plan=parsePlan(p.plan_json), notes=p.notes?`<div class="mini-task" style="margin-top:8px">${esc(p.notes.slice(0,140))}</div>`:'';
    return `<div class="project-card"><div class="project-head"><div onclick="openProject(${p.id})" style="cursor:pointer"><div class="project-title">${esc(p.name)}</div><div class="project-objective">${esc(p.objective||'')}</div></div><div class="section-count">${linked.length} open</div></div><ul class="project-plan">${plan.map(x=>`<li>${esc(x)}</li>`).join('')||'<li>Paste notes, click ✨ Draft next steps, then stage the best ones.</li>'}</ul>${notes}<div class="project-linked"><div class="mini-label">Current linked tasks</div>${linked.length?linked.slice(0,4).map(t=>`<div class="mini-task">• ${esc(t.title)}</div>`).join(''):'<div class="mini-task">No linked tasks yet.</div>'}</div><div class="modal-actions" style="margin-top:12px"><button class="btn-secondary" onclick="openProject(${p.id})">Edit</button><button class="btn-secondary" onclick="openProject(${p.id});setTimeout(()=>draftProjectPlanFromModal(),50)">✨ Draft</button><button class="btn-primary" onclick="stageProject(${p.id})">Stage tasks</button></div></div>`; }).join('');
  return `<div class="section"><div class="section-header"><div class="section-title">📁 Ongoing Projects</div><button class="btn-secondary" onclick="openProject()">+ Project</button></div>${cards||'<div class="empty-state"><div class="empty-icon">📁</div><div class="empty-title">No projects yet</div><div class="empty-sub">Create a project, save notes, click ✨ Draft next steps, then stage the real work.</div></div>'}</div>`;
}
