import type { CalendarItem, Task, RecurringTemplate, Project } from '../types.ts';
import { esc, weekItems, weekDays, sourceMeta, sourceBody, srcBadge, formatDue, pLabel, parseJson, parsePlan, smartTaskTitle } from '../utils/helpers.ts';
type Item = Task | RecurringTemplate | Project | null;
const asTime=(s='')=>{ const m=s.match(/(\d{1,2}):(\d{2})\s*([AP]M)/i); if(!m) return ''; const h=(parseInt(m[1])%12)+(m[3].toUpperCase()==='PM'?12:0); return `${String(h).padStart(2,'0')}:${m[2]}`; };
const guess=(t:Task)=>{ const m=parseJson(t.source_details), date=m.event_date||t.due_date||'', time=asTime(m.starts_at||''), title=(m.title||smartTaskTitle(t)||'').slice(0,120); return { title, date, time, location:m.location||'', duration:m.duration_minutes||60 }; };
const taskForm=(t?:Task|null)=>`<div class="modal-title">${t?'Edit task':'New task'}</div><div class="form-group"><label class="form-label">Title *</label><input class="form-input" id="inp-title" value="${esc(t?.title||'')}"></div><div class="form-group"><label class="form-label">Description</label><textarea class="form-textarea" id="inp-desc">${esc(t?.description||'')}</textarea></div><div class="form-row"><div class="form-group"><label class="form-label">Due date</label><input type="date" class="form-input" id="inp-due" value="${t?.due_date||''}"></div><div class="form-group"><label class="form-label">Priority</label><select class="form-select" id="inp-priority">${[1,2,3,4].map(n=>`<option value="${n}" ${(t?.priority||2)===n?'selected':''}>${pLabel(n)}</option>`).join('')}</select></div></div><div class="modal-actions"><button class="btn-secondary" onclick="closeModal()">Cancel</button><button class="btn-primary" onclick="saveTask()">Save</button></div>`;
const recurringForm=(r?:RecurringTemplate|null)=>`<div class="modal-title">${r?'Edit recurring task':'New recurring task'}</div><div class="form-group"><label class="form-label">Title *</label><input class="form-input" id="inp-title" value="${esc(r?.title||'')}"></div><div class="form-group"><label class="form-label">Description</label><textarea class="form-textarea" id="inp-desc">${esc(r?.description||'')}</textarea></div><div class="form-row"><div class="form-group"><label class="form-label">First due date *</label><input type="date" class="form-input" id="inp-due" value="${r?.next_due_date||''}"></div><div class="form-group"><label class="form-label">Priority</label><select class="form-select" id="inp-priority">${[1,2,3,4].map(n=>`<option value="${n}" ${(r?.priority||2)===n?'selected':''}>${pLabel(n)}</option>`).join('')}</select></div></div><div class="form-row"><div class="form-group"><label class="form-label">Repeat</label><select class="form-select" id="inp-frequency"><option value="daily" ${r?.frequency==='daily'?'selected':''}>Daily</option><option value="weekly" ${!r||r.frequency==='weekly'?'selected':''}>Weekly</option><option value="monthly" ${r?.frequency==='monthly'?'selected':''}>Monthly</option></select></div><div class="form-group"><label class="form-label">Every</label><input class="form-input" id="inp-interval" type="number" min="1" value="${r?.interval_n||1}"></div></div><div class="modal-actions"><button class="btn-secondary" onclick="closeModal()">Cancel</button><button class="btn-primary" onclick="saveRecurring()">Save</button></div>`;
const detail=(t:Task)=>`<div class="modal-title">Task details</div><div class="task-meta" style="margin-bottom:12px">${srcBadge(t.source)}${t.due_date?`<span class="task-due ${formatDue(t.due_date).cls}">📅 ${formatDue(t.due_date).text}</span>`:''}<span class="task-date">${pLabel(t.priority)}</span></div><div class="form-group"><label class="form-label">Task</label><div class="instr-desc">${esc(smartTaskTitle(t))}</div></div><div class="form-group"><label class="form-label">Original message</label><div class="instr-desc" style="white-space:pre-wrap">${esc(sourceBody(t))}</div></div><div class="form-group"><label class="form-label">Source details</label><div class="instr-desc">${sourceMeta(t).map(([k,v])=>`<div><strong>${esc(String(k))}:</strong> ${esc(String(v))}</div>`).join('')}</div></div><div class="modal-actions"><button class="btn-secondary" onclick="closeModal()">Close</button><button class="btn-secondary" onclick="openCalendar(${t.id})">Make calendar item</button><button class="btn-primary" onclick="editTask(${t.id})">Edit</button></div>`;
const projectForm=(p?:Project|null)=>{ const plan=parsePlan(p?.plan_json), status=p?.status||'active'; return `<div class="modal-title">${p?'Edit project':'New project'}</div><div class="form-group"><label class="form-label">Project name *</label><input class="form-input" id="inp-name" value="${esc(p?.name||'')}"></div><div class="form-group"><label class="form-label">Objective</label><textarea class="form-textarea" id="inp-objective">${esc(p?.objective||'')}</textarea></div><div class="form-group"><label class="form-label">Research / notes</label><textarea class="form-textarea" id="inp-notes">${esc(p?.notes||'')}</textarea></div><div class="form-row"><div class="form-group"><label class="form-label">Status</label><select class="form-select" id="inp-status"><option value="active" ${status==='active'?'selected':''}>Active</option><option value="paused" ${status==='paused'?'selected':''}>Paused</option><option value="done" ${status==='done'?'selected':''}>Done</option></select></div><div class="form-group"><label class="form-label">Planning</label><div class="instr-desc">${esc(p?.planning_summary||'Use Quick draft or Research + plan.')}</div></div></div><div class="form-group"><label class="form-label">Next steps</label><textarea class="form-textarea" id="inp-plan">${esc(plan.join('\n'))}</textarea></div><div class="form-group"><label class="form-label">Stage selected steps</label><div class="planner-picks" id="project-step-picks">${plan.length?plan.map((x,i)=>`<label class="pick-row"><input type="checkbox" checked value="${esc(x)}"><span>${i+1}. ${esc(x)}</span></label>`).join(''):'<div class="instr-desc">No steps yet. Draft or research a plan first.</div>'}</div></div><div class="modal-actions"><button class="btn-secondary" onclick="closeModal()">Cancel</button><button class="btn-secondary" onclick="draftProjectPlanFromModal()">⚡ Quick draft</button><button class="btn-secondary" onclick="queueProjectPlan()">✨ Research + plan</button><button class="btn-secondary" onclick="saveProject(false)">Save</button><button class="btn-primary" onclick="saveProject(true)">Save + Stage</button></div>`; };
const calendarForm=(t?:Task|null)=>{ const g=guess(t||({} as Task)); return `<div class="modal-title">Make calendar item</div><div class="form-group"><label class="form-label">Title *</label><input class="form-input" id="inp-title" value="${esc(g.title)}"></div><div class="form-row"><div class="form-group"><label class="form-label">Date *</label><input type="date" class="form-input" id="inp-date" value="${g.date||''}"></div><div class="form-group"><label class="form-label">Time *</label><input type="time" class="form-input" id="inp-time" value="${g.time||''}"></div></div><div class="form-row"><div class="form-group"><label class="form-label">Location</label><input class="form-input" id="inp-location" value="${esc(g.location||'')}"></div><div class="form-group"><label class="form-label">Duration (minutes)</label><input type="number" class="form-input" id="inp-duration" min="15" max="180" value="${g.duration||60}"></div></div><div class="modal-actions"><button class="btn-secondary" onclick="closeModal()">Cancel</button><button class="btn-primary" onclick="saveCalendar()">Create event</button></div>`; };
const eventCard=(i:CalendarItem)=>`<div class="week-slot"><div class="week-time">${i.starts_at||'All day'}</div><div><div class="week-title">${esc(i.title)}</div>${i.location?`<div class="week-sub">📍 ${esc(i.location)}</div>`:''}${i.html_link?`<a class="week-link" href="${esc(i.html_link)}" target="_blank">Open</a>`:''}</div></div>`;
const taskCard=(t:Task)=>`<div class="week-slot task"><div class="week-time">Due</div><div><div class="week-title" onclick="viewTask(${t.id})">${esc(smartTaskTitle(t))}</div><div class="week-sub">${pLabel(t.priority)} · ${esc(t.source==='manual'?'Task':t.source)}</div></div></div>`;
export const renderCalendar=(items:CalendarItem[],tasks:Task[])=>{ const ev=weekItems(items),days=weekDays(),today=new Date().toISOString().slice(0,10),dated=tasks.filter(t=>t.status==='open'&&t.due_date&&days.some(d=>d.key===t.due_date)); return `<div class="section"><div class="section-header"><div class="section-title">🗓 This week</div><div class="section-count">${ev.length+dated.length}</div></div><div class="week-grid">${days.map(d=>{ const cards=[...ev.filter(i=>i.event_date===d.key).sort((a,b)=>(a.starts_at||'').localeCompare(b.starts_at||'')).map(eventCard),...dated.filter(t=>t.due_date===d.key).sort((a,b)=>a.priority-b.priority||a.title.localeCompare(b.title)).map(taskCard)]; return `<div class="week-day ${d.key===today?'today':''}"><div class="week-head"><div><div class="week-label">${d.label}</div><div class="week-date">${d.day}</div></div><div class="week-badge">${cards.length}</div></div><div class="week-lane"><div class="week-lane-label">Scheduled</div><div class="week-slots">${cards.join('')||'<div class="week-empty">Nothing scheduled</div>'}</div></div></div>`; }).join('')}</div></div>`; };
export const renderHow=()=>`<div class="section"><div class="section-header"><div class="section-title">💡 Add things fast</div></div><div class="instruction-card"><div class="instr-title">Apple Messages</div><div class="instr-desc">Text yourself in Messages with <strong>task:</strong>, <strong>todo</strong>, <strong>reminder</strong>, or <strong>calendar event:</strong>. Explicit calendar texts auto-create events when they include a date/time.</div><div class="modal-actions"><button class="btn-secondary" onclick="syncNow()">↻ Sync all now</button><button class="btn-secondary" onclick="triggerMessagesScan()">▶ Scan Messages</button><button class="btn-secondary" onclick="triggerCalendarWriter()">▶ Check appointment texts</button></div></div><div class="instruction-card"><div class="instr-title">Email</div><div class="instr-desc">Forward or email tasks to yourself, then pull them into the task queue.</div><div class="modal-actions"><button class="btn-secondary" onclick="triggerEmailIngest()">▶ Check email tasks</button></div></div><div class="instruction-card"><div class="instr-title">Projects</div><div class="instr-desc">Create or edit a project, paste context, then click <strong>✨ Research + plan</strong> to let Pen draft usable next steps you can stage into tasks.</div></div></div>`;
export const renderModal=(item:Item,mode:string)=>`<div class="modal-overlay" id="modal-overlay"><div class="modal">${mode==='task'?taskForm(item as Task):mode==='recurring'?recurringForm(item as RecurringTemplate):mode==='project'?projectForm(item as Project):mode==='calendar'?calendarForm(item as Task):detail(item as Task)}</div></div>`;
