import type { CalendarItem, Task, RecurringTemplate, Project } from '../types.ts';
import { esc, fmtEvent, weekItems, sourceMeta, sourceBody, srcBadge, formatDue, pLabel, parseJson, parsePlan } from '../utils/helpers.ts';
type Item = Task | RecurringTemplate | Project | null;
const asTime=(s='')=>{ const m=s.match(/(\d{1,2}):(\d{2})\s*([AP]M)/i); if(!m) return ''; const h=(parseInt(m[1])%12)+(m[3].toUpperCase()==='PM'?12:0); return `${String(h).padStart(2,'0')}:${m[2]}`; };
const guess=(t:Task)=>{ const m=parseJson(t.source_details), date=m.event_date||t.due_date||'', time=asTime(m.starts_at||''), title=(m.title||t.title||'').slice(0,120); return { title, date, time, location:m.location||'', duration:m.duration_minutes||60 }; };
const taskForm=(t?:Task|null)=>`<div class="modal-title">${t?'Edit task':'New task'}</div><div class="form-group"><label class="form-label">Title *</label><input class="form-input" id="inp-title" value="${esc(t?.title||'')}"></div><div class="form-group"><label class="form-label">Description</label><textarea class="form-textarea" id="inp-desc">${esc(t?.description||'')}</textarea></div><div class="form-row"><div class="form-group"><label class="form-label">Due date</label><input type="date" class="form-input" id="inp-due" value="${t?.due_date||''}"></div><div class="form-group"><label class="form-label">Priority</label><select class="form-select" id="inp-priority">${[1,2,3,4].map(n=>`<option value="${n}" ${(t?.priority||2)===n?'selected':''}>${pLabel(n)}</option>`).join('')}</select></div></div><div class="modal-actions"><button class="btn-secondary" onclick="closeModal()">Cancel</button><button class="btn-primary" onclick="saveTask()">Save</button></div>`;
const recurringForm=(r?:RecurringTemplate|null)=>`<div class="modal-title">${r?'Edit recurring task':'New recurring task'}</div><div class="form-group"><label class="form-label">Title *</label><input class="form-input" id="inp-title" value="${esc(r?.title||'')}"></div><div class="form-group"><label class="form-label">Description</label><textarea class="form-textarea" id="inp-desc">${esc(r?.description||'')}</textarea></div><div class="form-row"><div class="form-group"><label class="form-label">First due date *</label><input type="date" class="form-input" id="inp-due" value="${r?.next_due_date||''}"></div><div class="form-group"><label class="form-label">Priority</label><select class="form-select" id="inp-priority">${[1,2,3,4].map(n=>`<option value="${n}" ${(r?.priority||2)===n?'selected':''}>${pLabel(n)}</option>`).join('')}</select></div></div><div class="form-row"><div class="form-group"><label class="form-label">Repeat</label><select class="form-select" id="inp-frequency"><option value="daily" ${r?.frequency==='daily'?'selected':''}>Daily</option><option value="weekly" ${!r||r.frequency==='weekly'?'selected':''}>Weekly</option><option value="monthly" ${r?.frequency==='monthly'?'selected':''}>Monthly</option></select></div><div class="form-group"><label class="form-label">Every</label><input class="form-input" id="inp-interval" type="number" min="1" value="${r?.interval_n||1}"></div></div><div class="modal-actions"><button class="btn-secondary" onclick="closeModal()">Cancel</button><button class="btn-primary" onclick="saveRecurring()">Save</button></div>`;
const detail=(t:Task)=>`<div class="modal-title">Task details</div><div class="task-meta" style="margin-bottom:12px">${srcBadge(t.source)}${t.due_date?`<span class="task-due ${formatDue(t.due_date).cls}">📅 ${formatDue(t.due_date).text}</span>`:''}<span class="task-date">${pLabel(t.priority)}</span></div><div class="form-group"><label class="form-label">Task</label><div class="instr-desc">${esc(t.title)}</div></div><div class="form-group"><label class="form-label">Original message</label><div class="instr-desc" style="white-space:pre-wrap">${esc(sourceBody(t))}</div></div><div class="form-group"><label class="form-label">Source details</label><div class="instr-desc">${sourceMeta(t).map(([k,v])=>`<div><strong>${esc(String(k))}:</strong> ${esc(String(v))}</div>`).join('')}</div></div><div class="modal-actions"><button class="btn-secondary" onclick="closeModal()">Close</button><button class="btn-secondary" onclick="openCalendar(${t.id})">Make calendar item</button><button class="btn-primary" onclick="editTask(${t.id})">Edit</button></div>`;
const project=(p?:Project|null)=>`<div class="modal-title">${p?'Edit project':'New project'}</div><div class="form-group"><label class="form-label">Project name *</label><input class="form-input" id="inp-name" value="${esc(p?.name||'')}"></div><div class="form-group"><label class="form-label">Objective</label><input class="form-input" id="inp-objective" value="${esc(p?.objective||'')}"></div><div class="form-group"><label class="form-label">Research / notes</label><textarea class="form-textarea" id="inp-notes" placeholder="Paste context, rough thoughts, vendor details, decisions, or research from chat.">${esc(p?.notes||'')}</textarea></div><div class="form-group"><label class="form-label">Next steps</label><textarea class="form-textarea" id="inp-plan" placeholder="One step per line">${esc(parsePlan(p?.plan_json||null).join('\n'))}</textarea><div class="instr-desc">Use chat to think, then click ✨ Draft next steps to turn notes into a workable plan.</div></div><div class="form-row"><div class="form-group"><label class="form-label">Status</label><select class="form-select" id="inp-status"><option value="active" ${p?.status==='active'?'selected':''}>Active</option><option value="paused" ${p?.status==='paused'?'selected':''}>Paused</option><option value="done" ${p?.status==='done'?'selected':''}>Done</option></select></div><div class="form-group"><label class="form-label">Workflow</label><div class="instr-desc">Save the project, then stage only the next few steps you actually want on your task list.</div></div></div><div class="modal-actions"><button class="btn-secondary" onclick="closeModal()">Cancel</button><button class="btn-secondary" onclick="draftProjectPlanFromModal()">✨ Draft next steps</button>${p?`<button class="btn-secondary" onclick="stageProject(${p.id})">Stage tasks</button>`:''}<button class="btn-primary" onclick="saveProject()">Save</button><button class="btn-primary" onclick="saveProject(true)">Save + Stage</button></div>`;
const calendar=(t:Task)=>{ const g=guess(t); return `<div class="modal-title">Create calendar item</div><div class="form-group"><label class="form-label">Title *</label><input class="form-input" id="inp-title" value="${esc(g.title)}"></div><div class="form-row"><div class="form-group"><label class="form-label">Date *</label><input type="date" class="form-input" id="inp-date" value="${g.date}"></div><div class="form-group"><label class="form-label">Time *</label><input type="time" class="form-input" id="inp-time" value="${g.time}"></div></div><div class="form-row"><div class="form-group"><label class="form-label">Location</label><input class="form-input" id="inp-location" value="${esc(g.location)}"></div><div class="form-group"><label class="form-label">Duration (min)</label><input type="number" min="15" max="180" class="form-input" id="inp-duration" value="${g.duration}"></div></div><div class="modal-actions"><button class="btn-secondary" onclick="closeModal()">Cancel</button><button class="btn-primary" onclick="saveCalendar()">Create event</button></div>`; };
export const renderCalendar=(items:CalendarItem[])=>{ const rows=weekItems(items); return !rows.length?'':`<div class="section"><div class="section-header"><div class="section-title">🗓 This week</div></div><div class="calendar-list">${rows.map(i=>`<div class="calendar-card"><div><div class="task-title">${esc(i.title)}</div><div class="task-description">${esc(fmtEvent(i))}${i.location?` · ${esc(i.location)}`:''}</div></div>${i.html_link?`<a class="icon-btn" href="${esc(i.html_link)}" target="_blank">↗</a>`:''}</div>`).join('')}</div></div>`; };
export const renderHow=()=>`<div class="instr-card"><h3>📱 Adding Tasks From Anywhere</h3><div class="instr-item"><div class="instr-icon">💬</div><div><div class="instr-title">Text yourself in Messages</div><div class="instr-desc">Send yourself <span class="code-pill">task: call dentist tomorrow</span>, <span class="code-pill">todo pay camp invoice Friday</span>, or <span class="code-pill">reminder send form tonight</span> in Apple Messages.<button class="run-btn" onclick="triggerMessagesScan()">▶ Check Messages</button></div></div></div><div class="instr-item"><div class="instr-icon">📧</div><div><div class="instr-title">Email a task from your phone</div><div class="instr-desc">Email yourself with <span class="code-pill">task:</span>, <span class="code-pill">todo:</span>, or <span class="code-pill">reminder:</span> if that’s quicker.<button class="run-btn" onclick="triggerEmailIngest()">▶ Check email tasks now</button></div></div></div><div class="instr-item"><div class="instr-icon">🗓</div><div><div class="instr-title">Appointment texts → calendar</div><div class="instr-desc">Date-and-time texts from Messages are reviewed as calendar candidates. Missing Google Calendar events get created automatically when confidence is high.<button class="run-btn" onclick="triggerCalendarWriter()">▶ Check appointment texts</button></div></div></div></div>`;
export const renderModal=(item:Item,mode:string)=>`<div class="modal-overlay" id="modal-overlay"><div class="modal">${mode==='detail'?detail(item as Task):mode==='recurring'?recurringForm(item as RecurringTemplate):mode==='project'?project(item as Project):mode==='calendar'?calendar(item as Task):taskForm(item as Task)}</div></div>`;
