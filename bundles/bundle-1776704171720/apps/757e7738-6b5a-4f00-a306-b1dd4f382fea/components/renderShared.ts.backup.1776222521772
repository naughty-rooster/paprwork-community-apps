import type { CalendarItem, Task, RecurringTemplate } from '../types.ts';
import { esc, fmtEvent, weekItems, sourceMeta, sourceBody, srcBadge, formatDue, pLabel } from '../utils/helpers.ts';
type Item = Task | RecurringTemplate | null;
export const renderCalendar=(items:CalendarItem[])=>{ const rows=weekItems(items); return rows.length?`<div class="section"><div class="section-header"><div class="section-title">🗓 This week</div></div><div class="calendar-list">${rows.map(i=>`<div class="calendar-card"><div><div class="task-title">${esc(i.title)}</div><div class="task-description">${esc(fmtEvent(i))}${i.location?` · ${esc(i.location)}`:''}</div></div>${i.html_link?`<a class="icon-btn" href="${esc(i.html_link)}" target="_blank">↗</a>`:''}</div>`).join('')}</div></div>`:''; };
export const renderHow=()=>`<div class="instr-card"><h3>📱 Adding Tasks From Anywhere</h3><div class="instr-item"><div class="instr-icon">💬</div><div><div class="instr-title">Text yourself in Messages</div><div class="instr-desc">On your Mac, send yourself <span class="code-pill">task: call dentist tomorrow</span>, <span class="code-pill">todo pay camp invoice Friday</span>, or <span class="code-pill">reminder send form tonight</span> in Apple Messages. The scanner turns it into a task.<button class="run-btn" onclick="triggerMessagesScan()">▶ Check Messages</button></div></div></div><div class="instr-item"><div class="instr-icon">📧</div><div><div class="instr-title">Email a task from your phone</div><div class="instr-desc">Email yourself with <span class="code-pill">task:</span>, <span class="code-pill">todo:</span>, or <span class="code-pill">reminder:</span> if that’s quicker than texting.<button class="run-btn" onclick="triggerEmailIngest()">▶ Check email tasks now</button></div></div></div><div class="instr-item"><div class="instr-icon">🗓</div><div><div class="instr-title">Appointment texts → calendar</div><div class="instr-desc">Appointment confirmations from Messages are classified as calendar items. If they are not already in Google Calendar, the writer tries to add them with provider, location, and duration details.<button class="run-btn" onclick="triggerCalendarWriter()">▶ Check appointment texts</button></div></div></div></div>`;
const recur=(f='weekly',n=1)=>`<div class="form-row"><div class="form-group"><label class="form-label">Repeat</label><select class="form-select" id="inp-frequency"><option value="weekly" ${f==='weekly'?'selected':''}>Weekly</option><option value="monthly" ${f==='monthly'?'selected':''}>Monthly</option><option value="daily" ${f==='daily'?'selected':''}>Daily</option></select></div><div class="form-group"><label class="form-label">Every</label><input class="form-input" id="inp-interval" type="number" min="1" value="${n}"></div></div>`;
const detail=(t:Task)=>`<div class="modal-title">Task details</div><div class="task-meta" style="margin-bottom:12px">${srcBadge(t.source)}${t.due_date?`<span class="task-due ${formatDue(t.due_date).cls}">📅 ${formatDue(t.due_date).text}</span>`:''}<span class="task-date">${pLabel(t.priority)}</span></div><div class="form-group"><label class="form-label">Task</label><div class="instr-desc">${esc(t.title)}</div></div><div class="form-group"><label class="form-label">Original message</label><div class="instr-desc" style="white-space:pre-wrap">${esc(sourceBody(t))}</div></div><div class="form-group"><label class="form-label">Source details</label><div class="instr-desc">${sourceMeta(t).map(([k,v])=>`<div><strong>${esc(String(k))}:</strong> ${esc(String(v))}</div>`).join('')}</div></div><div class="modal-actions"><button class="btn-secondary" onclick="closeModal()">Close</button><button class="btn-primary" onclick="editTask(${t.id})">Edit</button></div>`;
export function renderModal(item:Item, mode='task'){ if(mode==='detail'&&item) return `<div class="modal-overlay open" id="modal-overlay"><div class="modal">${detail(item as Task)}</div></div>`; const r=mode==='recurring', due=(item as any)?.due_date||(item as any)?.next_due_date||new Date().toISOString().slice(0,10), pri=(item as any)?.priority||2, ttl=(item as any)?.title||'', desc=(item as any)?.description||'', save=r?'saveRecurring()':'saveTask()';
  return `<div class="modal-overlay open" id="modal-overlay"><div class="modal"><div class="modal-title">${item?(r?'Edit recurring task':'Edit task'):(r?'+ Recurring Task':'+ New Task')}</div><div class="form-group"><label class="form-label">Title *</label><input class="form-input" id="inp-title" value="${esc(ttl)}"></div><div class="form-group"><label class="form-label">Description</label><textarea class="form-textarea" id="inp-desc">${esc(desc)}</textarea></div><div class="form-row"><div class="form-group"><label class="form-label">${r?'Next due':'Due date'}</label><input type="date" class="form-input" id="inp-due" value="${due}"></div><div class="form-group"><label class="form-label">Priority</label><select class="form-select" id="inp-priority"><option value="1" ${pri===1?'selected':''}>🔴 Urgent</option><option value="2" ${pri===2?'selected':''}>🟠 High</option><option value="3" ${pri===3?'selected':''}>🟡 Medium</option><option value="4" ${pri===4?'selected':''}>🟢 Low</option></select></div></div>${r?recur((item as any)?.frequency||'weekly',(item as any)?.interval_n||1):''}<div class="modal-actions"><button class="btn-secondary" onclick="closeModal()">Cancel</button><button class="btn-primary" onclick="${save}">Save</button></div></div></div>`; }
