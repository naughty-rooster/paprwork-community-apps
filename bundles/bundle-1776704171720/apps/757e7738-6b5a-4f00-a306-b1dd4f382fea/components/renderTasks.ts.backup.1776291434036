import type { Task, RecurringTemplate } from '../types.ts';
import { esc, formatDue, pLabel, srcBadge, emailStamp, tagLabel, getFocusTasks, activeTasks, isSomeday, sortTasks, smartTaskTitle } from '../utils/helpers.ts';
import { renderRecurring } from './renderRecurring.ts';
const desc=(t:Task)=>t.description?`<div class="task-description">${esc(t.description.slice(0,110))}</div>`:'';
const extra=(t:Task)=>`${emailStamp(t)?`<span class="task-date">✉ ${emailStamp(t)}</span>`:''}${tagLabel(t)?`<span class="task-date">📁 ${esc(tagLabel(t))}</span>`:''}`;
export function renderCard(t:Task){ const due=formatDue(t.due_date), done=t.status==='done'; return `<div class="task-card ${done?'done':''}"><button class="check-btn ${done?'checked':''}" onclick="event.stopPropagation();toggleDone(${t.id})">${done?'✓':''}</button><div class="task-content" onclick="viewTask(${t.id})"><div class="task-title">${esc(smartTaskTitle(t))}</div>${desc(t)}<div class="task-meta">${srcBadge(t.source)}${due.text?`<span class="task-due ${due.cls}">📅 ${due.text}</span>`:''}<span class="task-date">${pLabel(t.priority)}</span>${extra(t)}</div></div><div class="task-actions"><button class="icon-btn" onclick="event.stopPropagation();editTask(${t.id})">✏️</button><button class="icon-btn" onclick="event.stopPropagation();deleteTask(${t.id})">🗑️</button></div></div>`; }
export function renderToday(tasks:Task[]){ const open=activeTasks(tasks).filter(t=>t.status==='open'), rows=getFocusTasks(tasks), u=sortTasks(rows.filter(t=>t.priority===1)), h=sortTasks(rows.filter(t=>t.priority===2)), sec=(x:string,y:Task[])=>y.length?`<div class="section"><div class="section-header"><div class="section-title">${x}<span class="section-count">${y.length}</span></div></div><div class="task-list">${y.map(renderCard).join('')}</div></div>`:''; return `<div class="stats-row"><div class="stat-card"><div class="stat-num" style="color:var(--urgent)">${open.filter(t=>t.priority===1).length}</div><div class="stat-label">Urgent</div></div><div class="stat-card"><div class="stat-num" style="color:var(--high)">${open.filter(t=>t.priority===2).length}</div><div class="stat-label">High</div></div><div class="stat-card"><div class="stat-num" style="color:var(--medium)">${open.length}</div><div class="stat-label">Active</div></div><div class="stat-card"><div class="stat-num" style="color:var(--low)">${tasks.filter(t=>t.status==='done').length}</div><div class="stat-label">Done</div></div></div>`+(rows.length?sec('🔴 Critical',u)+sec('🟠 High Priority',h):'<div class="empty-state"><div class="empty-icon">✅</div><div class="empty-title">All clear</div></div>'); }
export function renderAll(tasks:Task[], rec:RecurringTemplate[], filter:string, search:string){ let f=tasks; if(filter==='active') f=f.filter(t=>t.status==='open'&&!isSomeday(t)); else if(filter==='someday') f=f.filter(t=>t.status==='open'&&isSomeday(t)); else if(filter==='messages') f=f.filter(t=>['messages','text_in','sms','sms_in'].includes(t.source)); else if(filter==='gmail') f=f.filter(t=>t.source==='gmail'); else if(filter==='email_in') f=f.filter(t=>t.source==='email_in'); else if(filter==='recurring') f=f.filter(t=>t.source==='recurring'); else if(filter!=='all') f=f.filter(t=>t.status===filter); if(search){ const q=search.toLowerCase(); f=f.filter(t=>[smartTaskTitle(t),t.description||'',t.tags||''].some(x=>x.toLowerCase().includes(q))); } f=sortTasks(f); const b=(v:string,l:string)=>`<button class="filter-btn ${filter===v?'active':''}" onclick="setFilter('${v}')">${l}</button>`; return `<div class="search-box"><span class="search-icon">🔍</span><input class="search-input" placeholder="Search tasks..." value="${esc(search)}" oninput="onSearch(this.value)"></div><div class="filter-row">${b('active','Active')}${b('messages','Messages')}${b('gmail','Gmail')}${b('email_in','Email-in')}${b('recurring','Recurring')}${b('someday','Someday')}${b('done','Done')}${b('all','All')}</div>${renderRecurring(rec)}<div class="task-list">${f.map(renderCard).join('')||'<div class="empty-state"><div class="empty-title">No matching tasks</div></div>'}</div>`; }
