import type { Task, CalendarItem, Project, MessageCandidate, RecurringTemplate } from './types.ts';
import { dbQuery, dbWrite, triggerJob, parseJson, parsePlan, sourceBody } from './utils/helpers.ts';
import { draftProjectPlan } from './utils/projectMagic.ts';
import { renderToday, renderAll } from './components/renderTasks.ts';
import { renderProjects } from './components/renderProjects.ts';
import { renderCalendar, renderHow, renderModal } from './components/renderShared.ts';
import { renderMessages } from './components/renderMessages.ts';
let tasks:Task[]=[], items:CalendarItem[]=[], projects:Project[]=[], candidates:MessageCandidate[]=[], recurring:RecurringTemplate[]=[];
let currentTab='today', filterStatus='active', searchQuery='', showAddModal=false, selectedTask:Task|null=null, selectedRecurring:RecurringTemplate|null=null, selectedProject:Project|null=null, modalMode='task';
const IDS={ email:'737c7fef-1c21-4522-85f1-9d4388a080f2', messages:'1833eaea-ea37-427d-bf45-b02c063f00cd', calendar:'9119a317-00c7-499a-8d94-f16c67327d66', recurring:'4ef2431d-2fb3-4d93-9456-374eaceffbee' };
const app=()=>document.getElementById('app')!, el=(id:string)=>document.getElementById(id) as HTMLInputElement|HTMLTextAreaElement|HTMLSelectElement|null, val=(id:string)=>(el(id)?.value||'').trim();
const body=()=>currentTab==='today'?renderToday(tasks)+renderCalendar(items):currentTab==='all'?renderAll(tasks,recurring,filterStatus,searchQuery):currentTab==='projects'?renderProjects(projects,tasks):renderHow()+renderMessages(candidates);
const toast=(m:string)=>{ const t=document.getElementById('toast'); if(t){ t.textContent=m; t.classList.add('show'); setTimeout(()=>t.classList.remove('show'),2500); } };
function main(){ app().innerHTML=`<div class="header"><div class="header-left"><div class="app-icon">📋</div><div><div class="app-title">Personal Admin Assistant</div><div class="app-subtitle">${new Date().toLocaleDateString('en',{weekday:'long',month:'long',day:'numeric'})}</div></div></div><div class="header-actions"><button class="btn-secondary" onclick="loadData()">↻</button><button class="btn-secondary" onclick="openRecurring()">↺ Recurring</button><button class="btn-primary" onclick="openAdd()">+ Add Task</button></div></div><div class="tabs"><div class="tab ${currentTab==='today'?'active':''}" onclick="switchTab('today')">📌 Focus</div><div class="tab ${currentTab==='all'?'active':''}" onclick="switchTab('all')">📋 Tasks</div><div class="tab ${currentTab==='projects'?'active':''}" onclick="switchTab('projects')">📁 Projects</div><div class="tab ${currentTab==='how'?'active':''}" onclick="switchTab('how')">💡 Add</div></div><div class="main">${body()}</div>${showAddModal?renderModal((selectedProject||selectedRecurring||selectedTask) as any,modalMode):''}<div class="toast" id="toast"></div>`; document.getElementById('modal-overlay')?.addEventListener('click',e=>{ if((e.target as HTMLElement).id==='modal-overlay') closeModal(); }); }
async function loadData(){ app().innerHTML='<div class="loading"><div class="spinner"></div> Loading…</div>'; [tasks,items,projects,candidates,recurring]=await Promise.all([dbQuery(`SELECT * FROM tasks ORDER BY priority ASC, due_date ASC NULLS LAST, created_at DESC`),dbQuery(`SELECT * FROM calendar_items ORDER BY event_date ASC, starts_at ASC`),dbQuery(`SELECT * FROM projects ORDER BY name ASC`),dbQuery(`SELECT * FROM message_candidates WHERE status='new' AND datetime(message_date)>=datetime('now','-21 days') AND COALESCE(json_extract(source_details,'$.category'),'')!='family-logistics' ORDER BY datetime(message_date) DESC, score DESC LIMIT 12`),dbQuery(`SELECT * FROM recurring_templates ORDER BY CASE status WHEN 'active' THEN 0 ELSE 1 END, next_due_date ASC, title ASC`)]); main(); }
const closeModal=()=>{ showAddModal=false; selectedTask=null; selectedRecurring=null; selectedProject=null; modalMode='task'; main(); };
const openAdd=()=>{ closeModal(); modalMode='task'; showAddModal=true; main(); }; const openRecurring=()=>{ closeModal(); modalMode='recurring'; showAddModal=true; main(); };
const openProject=(id?:number)=>{ closeModal(); selectedProject=id?projects.find(p=>p.id===id)||null:null; modalMode='project'; showAddModal=true; main(); };
const openCalendar=(id:number)=>{ closeModal(); selectedTask=tasks.find(t=>t.id===id)||null; if(selectedTask){ modalMode='calendar'; showAddModal=true; main(); } };
const run=async(id:string,msg:string)=>{ toast(msg); await triggerJob(id); setTimeout(loadData,2500); };
async function persistProject(stage=false){ const name=val('inp-name'); if(!name) return; const objective=val('inp-objective'), notes=val('inp-notes'), status=val('inp-status')||'active', plan=val('inp-plan').split('\n').map(x=>x.replace(/^[-*\d.\s]+/,'').trim()).filter(Boolean); if(selectedProject) await dbWrite(`UPDATE projects SET name=?,objective=?,notes=?,status=?,plan_json=?,updated_at=datetime('now') WHERE id=?`,[name,objective,notes,status,JSON.stringify(plan),selectedProject.id]); else await dbWrite(`INSERT INTO projects (name,objective,notes,status,plan_json) VALUES (?,?,?,?,?)`,[name,objective,notes,status,JSON.stringify(plan)]); await loadData(); const saved=projects.find(p=>p.name===name)||selectedProject; if(stage&&saved) await stageProject(saved.id); else { closeModal(); toast('📁 Project saved'); } }
async function stageProject(id:number){ const p=projects.find(x=>x.id===id)||selectedProject; if(!p) return; const steps=parsePlan(p.plan_json).slice(0,8); let made=0; for(const step of steps){ const exists=tasks.find(t=>t.status==='open'&&(t.tags||'').includes(`project:${p.name}`)&&t.title.toLowerCase()===step.toLowerCase()); if(exists) continue; await dbWrite(`INSERT INTO tasks (title,description,priority,status,source,tags,source_details) VALUES (?,?,2,'open','manual',?,?)`,[step,p.objective||'',`project:${p.name}`,JSON.stringify({project:p.name,staged_from:'project_plan'})]); made++; } await loadData(); closeModal(); toast(made?`✅ Staged ${made} project task${made===1?'':'s'}`:'No new project tasks to stage'); }
(window as any).loadData=loadData; (window as any).switchTab=(t:string)=>{ currentTab=t; main(); }; (window as any).setFilter=(f:string)=>{ filterStatus=f; main(); }; (window as any).onSearch=(v:string)=>{ searchQuery=v; main(); };
(window as any).openAdd=openAdd; (window as any).openRecurring=openRecurring; (window as any).closeModal=closeModal; (window as any).openProject=openProject; (window as any).openCalendar=openCalendar;
(window as any).viewTask=(id:number)=>{ selectedTask=tasks.find(t=>t.id===id)||null; selectedRecurring=null; selectedProject=null; modalMode='detail'; showAddModal=!!selectedTask; main(); };
(window as any).editTask=(id:number)=>{ selectedTask=tasks.find(t=>t.id===id)||null; selectedRecurring=null; selectedProject=null; modalMode='task'; showAddModal=!!selectedTask; main(); };
(window as any).editRecurring=(id:number)=>{ selectedRecurring=recurring.find(r=>r.id===id)||null; selectedTask=null; selectedProject=null; modalMode='recurring'; showAddModal=!!selectedRecurring; main(); };
(window as any).toggleDone=async(id:number)=>{ const t=tasks.find(x=>x.id===id); if(!t) return; const s=t.status==='done'?'open':'done'; await dbWrite(`UPDATE tasks SET status=?,updated_at=datetime('now') WHERE id=?`,[s,id]); t.status=s; main(); toast(s==='done'?'✅ Completed':'↩️ Reopened'); };
(window as any).deleteTask=async(id:number)=>{ if(confirm('Delete this task?')){ await dbWrite(`DELETE FROM tasks WHERE id=?`,[id]); tasks=tasks.filter(t=>t.id!==id); main(); toast('🗑️ Deleted'); } };
(window as any).saveTask=async()=>{ const title=val('inp-title'); if(!title) return; const desc=val('inp-desc'), due=val('inp-due')||null, pri=parseInt(val('inp-priority')||'2'); if(selectedTask) await dbWrite(`UPDATE tasks SET title=?,description=?,due_date=?,priority=?,updated_at=datetime('now') WHERE id=?`,[title,desc,due,pri,selectedTask.id]); else await dbWrite(`INSERT INTO tasks (title,description,due_date,priority,status,source) VALUES (?,?,?,?,'open','manual')`,[title,desc,due,pri]); closeModal(); await loadData(); toast('✅ Saved'); };
(window as any).saveRecurring=async()=>{ const title=val('inp-title'), due=val('inp-due'); if(!title||!due) return; const desc=val('inp-desc'), pri=parseInt(val('inp-priority')||'2'), freq=val('inp-frequency')||'weekly', n=parseInt(val('inp-interval')||'1'), dt=new Date(due+'T00:00:00'), weekday=(dt.getDay()+6)%7, day=dt.getDate(); if(selectedRecurring) await dbWrite(`UPDATE recurring_templates SET title=?,description=?,priority=?,frequency=?,interval_n=?,next_due_date=?,weekday=?,day_of_month=?,updated_at=datetime('now') WHERE id=?`,[title,desc,pri,freq,n,due,weekday,day,selectedRecurring.id]); else { await dbWrite(`INSERT INTO recurring_templates (title,description,priority,frequency,interval_n,start_date,next_due_date,weekday,day_of_month,status) VALUES (?,?,?,?,?,?,?,?,?,'active')`,[title,desc,pri,freq,n,due,due,weekday,day]); await triggerJob(IDS.recurring); } closeModal(); await loadData(); toast('↺ Recurring saved'); };
(window as any).draftProjectPlanFromModal=()=>{ const plan=draftProjectPlan(val('inp-name'),val('inp-objective'),val('inp-notes')); const box=el('inp-plan') as HTMLTextAreaElement|null; if(box){ box.value=plan.join('\n'); toast(plan.length?'✨ Drafted next steps':'Add more notes first'); } };
(window as any).saveProject=(stage=false)=>persistProject(!!stage); (window as any).stageProject=stageProject;
(window as any).saveCalendar=async()=>{ if(!selectedTask) return; const title=val('inp-title')||selectedTask.title, event_date=val('inp-date'), starts_at=val('inp-time'), location=val('inp-location'), mins=parseInt(val('inp-duration')||'60'); if(!title||!event_date||!starts_at) return; const [hh0,mm='00']=starts_at.split(':'), h24=parseInt(hh0||'0'), hh=((h24+11)%12)+1, ap=h24>=12?'PM':'AM', meta=parseJson(selectedTask.source_details); Object.assign(meta,{ classification:'calendar', capture_mode:meta.capture_mode||selectedTask.source||'task', calendar_confidence:1, duration_minutes:Math.max(15,Math.min(180,mins||60)), source_task_id:selectedTask.id, notes:sourceBody(selectedTask) }); await dbWrite(`INSERT INTO calendar_items (title,event_date,starts_at,location,source_details) VALUES (?,?,?,?,?)`,[title,event_date,`${hh}:${mm.padStart(2,'0')} ${ap}`,location,JSON.stringify(meta)]); closeModal(); await loadData(); await triggerJob(IDS.calendar); toast('🗓 Calendar item queued for Google Calendar'); };
(window as any).toggleRecurring=async(id:number)=>{ const r=recurring.find(x=>x.id===id); if(!r) return; const s=r.status==='active'?'paused':'active'; await dbWrite(`UPDATE recurring_templates SET status=?,updated_at=datetime('now') WHERE id=?`,[s,id]); r.status=s; main(); toast(s==='active'?'▶ Resumed':'⏸ Paused'); };
(window as any).deleteRecurring=async(id:number)=>{ if(confirm('Delete this recurring template?')){ await dbWrite(`DELETE FROM recurring_templates WHERE id=?`,[id]); recurring=recurring.filter(r=>r.id!==id); main(); toast('🗑️ Recurring deleted'); } };
(window as any).promoteCandidate=async(id:number)=>{ const c=candidates.find(x=>x.id===id); if(!c) return; const meta=parseJson(c.source_details), source=meta.capture_mode==='sms'?'sms':'messages'; await dbWrite(`INSERT INTO tasks (title,description,priority,status,source,source_details) VALUES (?,?,?,?,?,?)`,[c.message_text.slice(0,120),c.message_text,2,'open',source,c.source_details]); await dbWrite(`UPDATE message_candidates SET status='promoted',updated_at=datetime('now') WHERE id=?`,[id]); candidates=candidates.filter(x=>x.id!==id); await loadData(); toast('✅ Promoted to task'); };
(window as any).ignoreCandidate=async(id:number)=>{ await dbWrite(`UPDATE message_candidates SET status='ignored',updated_at=datetime('now') WHERE id=?`,[id]); candidates=candidates.filter(x=>x.id!==id); main(); toast('🙈 Ignored'); };
(window as any).triggerEmailIngest=()=>run(IDS.email,'📧 Checking emailed tasks...'); (window as any).triggerMessagesScan=()=>run(IDS.messages,'💬 Scanning Messages...'); (window as any).triggerCalendarWriter=()=>run(IDS.calendar,'🗓 Adding appointment texts to Google Calendar...');
loadData();
